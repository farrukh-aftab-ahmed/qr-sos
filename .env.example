# ─── Database ────────────────────────────────────────────────────────────────
# Local dev: postgresql://qrsos:qrsos123@localhost:5432/qrsos
# Docker:    postgresql://qrsos:<POSTGRES_PASSWORD>@postgres:5432/qrsos
DATABASE_URL="postgresql://qrsos:qrsos123@localhost:5432/qrsos"

# ─── Postgres password (Docker Compose only) ─────────────────────────────────
POSTGRES_PASSWORD="qrsos123"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# Free tier at https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# ─── Redis ───────────────────────────────────────────────────────────────────
# Local Docker Redis (no token needed for dev)
UPSTASH_REDIS_REST_URL="http://localhost:6379"
UPSTASH_REDIS_REST_TOKEN="local-dev-token"
REDIS_URL="redis://localhost:6379"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Free tier at https://resend.com (100 emails/day)
RESEND_API_KEY="re_your_key_here"
EMAIL_FROM="noreply@yourdomain.com"

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@yourdomain.com"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="QR-SOS"
